# Nexora Backend Environment Configuration

# Database Connection URL (PostgreSQL asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexora

# Allowed CORS Origin (Vite frontend URL)
ALLOWED_ORIGIN=http://localhost:5173

# Custom JWT Authentication Settings
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Backblaze B2 Pooled Storage Configuration
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=your_backblaze_b2_application_key_id
B2_APP_KEY=your_backblaze_b2_application_key
B2_BUCKET=nexorav1

# IDrive e2 Pooled Storage Configuration
E2_ENDPOINT=https://s3.ap-northeast-1.idrivee2.com
E2_KEY_ID=your_idrive_e2_access_key_id
E2_APP_KEY=your_idrive_e2_secret_access_key
E2_BUCKET=nexorav1
